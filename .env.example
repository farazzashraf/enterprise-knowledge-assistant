# ── Gemini API ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIM=768

# ── Qdrant ───────────────────────────────────────────────────
# Default: local Qdrant (run via docker compose). docker-compose overrides this
# to http://qdrant:6333 for the containers; host/venv use localhost as below.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=knowledge_base
# Qdrant Cloud alternative: set the URL + key from your cluster and re-ingest.
# QDRANT_URL=https://your-cluster-id.cloud.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key_here

# ── Retrieval ────────────────────────────────────────────────
CHUNK_SIZE=600           # tokens (tiktoken cl100k_base)
CHUNK_OVERLAP=0.15       # fraction of CHUNK_SIZE
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
CONFIDENCE_THRESHOLD=0.10   # floor on top reranker probability (0-1); abstain below it

# ── Reranking ────────────────────────────────────────────────
USE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-base

# ── BM25 Persistence ────────────────────────────────────────
BM25_INDEX_PATH=data/bm25_index.pkl
BM25_CORPUS_PATH=data/bm25_corpus.pkl

# ── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ── Streamlit ────────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Feedback ─────────────────────────────────────────────────
FEEDBACK_LOG_PATH=data/feedback.jsonl
